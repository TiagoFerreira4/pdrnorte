---
import WhatsAppButton from './WhatsAppButton.astro'
import { contactMessages, siteConfig } from '../data/site'
---

<footer class="border-t border-white/8 bg-[#04060a]">
  <div
    class="mx-auto grid max-w-7xl gap-10 px-4 py-12 sm:px-6 lg:grid-cols-[1.1fr_0.9fr_0.9fr] lg:px-8"
  >
    <div class="max-w-md">
      <p class="font-display text-3xl font-semibold text-white">PDR Norte</p>
      <p class="mt-4 text-sm leading-7 text-slate-400">
        A PDR Norte é um centro automotivo em Recife especializado em martelinho
        de ouro, películas e estética automotiva.
      </p>
      <div class="mt-6">
        <WhatsAppButton
          label="Falar com a PDR Norte"
          message={contactMessages.quote}
        />
      </div>
    </div>

    <div>
      <p class="eyebrow">Contato</p>
      <ul class="mt-4 space-y-3 text-sm text-slate-300">
        <li>WhatsApp: {siteConfig.whatsappLabel}</li>
        <li>
          Instagram:
          <a
            class="text-white transition hover:text-brand-blue"
            href={siteConfig.instagramUrl}
            target="_blank"
            rel="noreferrer"
          >
            {siteConfig.instagramLabel}
          </a>
        </li>
        <li>Endereço: {siteConfig.address}</li>
      </ul>
    </div>

    <div>
      <p class="eyebrow">Horário</p>
      <ul class="mt-4 space-y-3 text-sm text-slate-300">
        <li>Segunda a sexta: 08h às 17h</li>
        <li>Sábado: 08h às 14h</li>
      </ul>
    </div>
  </div>
</footer>
