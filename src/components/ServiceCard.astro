---
interface Props {
	title: string;
	description: string;
	badge?: string;
	href?: string;
}

const { title, description, badge = 'PDR', href } = Astro.props;
---

{
	href ? (
		<a
			href={href}
			class="section-surface group flex h-full flex-col rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:border-brand-blue/28 hover:bg-white/9 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-blue/60 focus-visible:ring-offset-2 focus-visible:ring-offset-[#05070b]"
		>
			<div class="mb-6 inline-flex min-h-12 min-w-[6.75rem] items-center justify-center rounded-2xl border border-brand-blue/20 bg-brand-blue/10 px-4 py-3 text-brand-blue">
				<span class="whitespace-nowrap font-display text-sm font-semibold tracking-[0.16em]">{badge}</span>
			</div>
			<h3 class="text-2xl font-semibold text-white">{title}</h3>
			<p class="mt-4 text-sm leading-7 text-slate-300">{description}</p>
		</a>
	) : (
		<article class="section-surface group flex h-full flex-col rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:border-brand-blue/28 hover:bg-white/9">
			<div class="mb-6 inline-flex min-h-12 min-w-[6.75rem] items-center justify-center rounded-2xl border border-brand-blue/20 bg-brand-blue/10 px-4 py-3 text-brand-blue">
				<span class="whitespace-nowrap font-display text-sm font-semibold tracking-[0.16em]">{badge}</span>
			</div>
			<h3 class="text-2xl font-semibold text-white">{title}</h3>
			<p class="mt-4 text-sm leading-7 text-slate-300">{description}</p>
		</article>
	)
}
