---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { siteConfig } from '../data/site';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = siteConfig.defaultTitle,
	description = siteConfig.defaultDescription,
} = Astro.props;

const siteUrl = 'https://www.pdrnorte.com.br';
const localBusinessSchema = {
	'@context': 'https://schema.org',
	'@type': 'LocalBusiness',
	'@id': siteUrl,
	name: siteConfig.name,
	description: siteConfig.defaultDescription,
	url: siteUrl,
	telephone: siteConfig.whatsappLabel,
	image: `${siteUrl}/images/placeholders/logo-pdr-norte.jpg`,
	sameAs: [siteConfig.instagramUrl],
	address: {
		'@type': 'PostalAddress',
		streetAddress: 'Av. Norte Miguel Arraes de Alencar, 1795, Loja 5 e 6',
		addressLocality: 'Recife',
		addressRegion: 'PE',
		postalCode: '52021-000',
		addressCountry: 'BR',
	},
	geo: {
		'@type': 'GeoCoordinates',
		latitude: -8.040337580296583,
		longitude: -34.88971652316589,
	},
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
			opens: '08:00',
			closes: '17:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: 'Saturday',
			opens: '08:00',
			closes: '14:00',
		},
	],
};
---

<!doctype html>
<html lang="pt-BR">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:locale" content="pt_BR" />
		<script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
	</head>
	<body class="selection:bg-brand-blue/30 selection:text-black">
		<div
			aria-hidden="true"
			class="pointer-events-none fixed inset-x-0 top-0 -z-10 h-[34rem] bg-[radial-gradient(circle_at_top,rgba(244,197,66,0.22),transparent_38%),linear-gradient(180deg,#06080d_0%,#020407_100%)]"
		></div>
		<div
			aria-hidden="true"
			class="pointer-events-none fixed inset-0 -z-20 bg-[linear-gradient(180deg,rgba(255,255,255,0.02)_0%,rgba(255,255,255,0)_32%)]"
		></div>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
