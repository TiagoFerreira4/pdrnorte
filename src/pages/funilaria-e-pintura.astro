---
import WhatsAppButton from '../components/WhatsAppButton.astro';
import {
	contactMessages,
	funilariaBenefits,
	funilariaIndications,
	siteConfig,
} from '../data/site';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Funilaria e Pintura em Recife | PDR Norte"
	description="Reparamos avarias, corrigimos a lataria e restauramos o acabamento do seu veículo com qualidade profissional na PDR Norte em Recife."
>
	<section class="scroll-mt-28">
		<div class="funilaria-hero-panel overflow-hidden border-b border-white/8">
			<div class="mx-auto flex min-h-[100svh] max-w-7xl items-start px-4 pt-28 pb-16 sm:px-6 sm:pt-32 lg:px-8 lg:pt-36 lg:pb-24">
				<div class="max-w-3xl">
					<p class="eyebrow">Funilaria e pintura</p>
					<h1 class="mt-5 text-4xl font-semibold tracking-[0.01em] text-white sm:text-5xl lg:text-7xl">
						Funilaria e Pintura em Recife
					</h1>
					<p class="mt-6 max-w-2xl text-base leading-7 text-slate-200 sm:text-lg">
						Reparamos avarias, corrigimos a lataria e restauramos o acabamento
						do seu veículo com qualidade profissional.
					</p>
					<div class="mt-8">
						<WhatsAppButton
							label="Solicitar orçamento pelo WhatsApp"
							message={contactMessages.funilaria}
						/>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section id="quando-indicado" class="section-layer scroll-mt-28">
		<div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
			<div class="max-w-3xl">
				<p class="eyebrow">Quando é indicado</p>
				<h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
					Casos em que a funilaria e pintura se tornam a solução mais adequada.
				</h2>
			</div>
			<div class="mt-10 grid gap-5 md:grid-cols-2 xl:grid-cols-4">
				{
					funilariaIndications.map((item) => (
						<article class="section-surface rounded-[1.75rem] p-6 transition hover:-translate-y-1 hover:border-brand-blue/28 hover:bg-white/9">
							<h3 class="text-2xl font-semibold text-white">{item}</h3>
						</article>
					))
				}
			</div>
		</div>
	</section>

	<section class="section-layer scroll-mt-28">
		<div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
			<div class="grid gap-6 lg:grid-cols-2">
				<article class="section-surface hex-surface rounded-[2rem] p-8 sm:p-10 lg:p-12">
					<p class="eyebrow">Funilaria</p>
					<h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
						Correção da estrutura da lataria e recuperação das áreas danificadas.
					</h2>
					<p class="mt-5 text-base leading-8 text-slate-300">
						A funilaria atua na correção da estrutura da lataria, no alinhamento
						de peças e na recuperação de áreas que sofreram impacto, deformação
						ou desalinhamento.
					</p>
				</article>

				<article class="section-surface rounded-[2rem] p-8 sm:p-10 lg:p-12">
					<p class="eyebrow">Pintura automotiva</p>
					<h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
						Recuperação do acabamento com pintura profissional.
					</h2>
					<p class="mt-5 text-base leading-8 text-slate-300">
						A pintura automotiva recupera o acabamento do veículo e devolve o
						visual original com aplicação profissional, atenção ao resultado
						final e cuidado com a apresentação do carro.
					</p>
				</article>
			</div>
		</div>
	</section>

	<section class="section-layer scroll-mt-28">
		<div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
			<div class="section-surface rounded-[2rem] p-8 sm:p-10 lg:p-14">
				<div class="max-w-3xl">
					<p class="eyebrow">Benefícios</p>
					<h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
						O que a funilaria e pintura entregam quando o dano exige uma solução completa.
					</h2>
				</div>
				<div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
					{
						funilariaBenefits.map((benefit) => (
							<div class="rounded-[1.5rem] border border-white/10 bg-white/5 px-5 py-5 text-sm font-medium leading-7 text-slate-200">
								{benefit}
							</div>
						))
					}
				</div>
			</div>
		</div>
	</section>

	<section class="section-layer scroll-mt-28">
		<div class="mx-auto max-w-7xl px-4 pb-20 sm:px-6 lg:px-8">
			<div class="section-surface hex-surface rounded-[2rem] p-8 sm:p-10 lg:p-14">
				<div class="grid gap-8 lg:grid-cols-[1.08fr_0.92fr] lg:items-center">
					<div class="max-w-3xl">
						<p class="eyebrow">Funilaria ou Martelinho?</p>
						<h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
							Entenda rapidamente qual caminho costuma fazer mais sentido.
						</h2>
						<div class="mt-6 space-y-4 text-base leading-8 text-slate-300">
							<p>
								Se a pintura estiver intacta, o martelinho pode resolver.
							</p>
							<p>
								Se houver dano na pintura ou deformação forte, o ideal é
								funilaria e pintura.
							</p>
						</div>
					</div>
					<div class="section-surface rounded-[1.75rem] p-6 sm:p-8">
						<p class="eyebrow">Avaliação</p>
						<h3 class="mt-4 text-2xl font-semibold text-white">
							Envie fotos para avaliação
						</h3>
						<p class="mt-4 text-sm leading-7 text-slate-300">
							A equipe analisa o cenário inicial e orienta se o caso tende mais
							para martelinho de ouro ou para funilaria e pintura.
						</p>
						<div class="mt-6">
							<WhatsAppButton
								label="Enviar fotos para avaliação"
								message={contactMessages.funilariaPhotos}
							/>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section-layer scroll-mt-28">
		<div class="mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
			<div class="section-surface hex-surface rounded-[2rem] px-8 py-10 sm:px-10 lg:px-14 lg:py-14">
				<div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
					<div class="max-w-2xl">
						<p class="eyebrow">Contato</p>
						<h2 class="mt-4 text-3xl font-semibold text-white sm:text-4xl">
							Quer avaliar a avaria do seu veículo?
						</h2>
						<p class="mt-4 text-base leading-7 text-slate-300">
							Fale com a equipe da PDR Norte pelo WhatsApp ou acompanhe o
							Instagram da loja para conhecer mais do padrão de acabamento.
						</p>
					</div>
					<div class="flex flex-col gap-3 sm:flex-row">
						<WhatsAppButton
							label="Pedir orçamento"
							message={contactMessages.funilaria}
						/>
						<a
							class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/6 px-6 py-3 text-sm font-semibold tracking-[0.08em] text-white transition hover:border-brand-blue/50 hover:bg-white/10"
							href={siteConfig.instagramUrl}
							target="_blank"
							rel="noreferrer"
						>
							Ver Instagram
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>
